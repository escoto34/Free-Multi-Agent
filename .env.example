# =============================================================================
# Multi-Agent Ecosystem — Environment Variables
# Copy to .env and fill keys you use. Only providers assigned in
# config/model_router.yaml (or as fallbacks) are required at runtime.
# Set via CLI: multiagent keys set <provider>
# List platforms: multiagent providers
# =============================================================================

# --- Core free tiers (used by default System A/B) ---

# Groq — https://console.groq.com/keys
# Free: ~1,000 RPD per model. Speedy; compound-mini has built-in web search.
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — https://openrouter.ai/keys
# Free: ~50 RPD shared across :free models (~1,000 with $10 credit).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cohere — https://dashboard.cohere.com/api-keys
# Trial: ~1,000 calls/month (~25-30/day). Non-commercial on trial — check ToS.
COHERE_API_KEY=your_cohere_api_key_here

# --- Optional free-friendly platforms (assign with /config set) ---

# Mistral Studio Free / Experiment — https://console.mistral.ai
# codestral-latest, mistral-small-latest, devstral-latest, open-mistral-nemo
MISTRAL_API_KEY=your_mistral_api_key_here

# Google AI Studio (Gemini free) — https://aistudio.google.com/apikey
# gemini-2.5-flash, gemini-2.0-flash (OpenAI-compatible endpoint)
GEMINI_API_KEY=your_gemini_api_key_here

# Cerebras free developer — https://cloud.cerebras.ai
# llama-3.3-70b, qwen-3-32b (very fast inference)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# --- Local + free multimodal gateways ---

# Ollama (local) — https://ollama.com/download
# OpenAI-compatible at http://localhost:11434/v1 — NO key required.
# MultiAgent lists ONLY models from `ollama list` (daemon), never a fake catalog.
# Pull what you need: ollama pull llama3.2
# Assign using the exact name from `ollama list`, e.g.:
#   multiagent config set cli.chat ollama llama3.2:latest
# OLLAMA_API_KEY=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_HOST=http://localhost:11434

# Agnes AI free multimodal gateway — https://platform.agnes-ai.com
# OpenAI-compatible: https://apihub.agnes-ai.com/v1
# Free text model (default chat/planner/architect/compressor): agnes-2.0-flash
# Also free (other endpoints): agnes-image-2.0-flash, agnes-image-2.1-flash, agnes-video-v2.0
# Defaults already use Agnes — only need the key:
AGNES_API_KEY=your_agnes_api_key_here
