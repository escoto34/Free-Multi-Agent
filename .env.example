# =============================================================================
# Multi-Agent Ecosystem — Environment Variables
# Copy this file to .env and fill in your API keys.
# =============================================================================

# Groq — https://console.groq.com/keys
# Free tier: ~1,000 RPD per model (we use 80% = 800 as safe limit)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — https://openrouter.ai/keys
# Free tier: ~50 RPD shared across all :free models (we use 90% = 45 as safe limit)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cohere — https://dashboard.cohere.com/api-keys
# Trial tier: ~1,000 calls/month shared across all endpoints (~25-30/day)
# NOTE: Cohere trial tier is contractually non-commercial use only.
COHERE_API_KEY=your_cohere_api_key_here
